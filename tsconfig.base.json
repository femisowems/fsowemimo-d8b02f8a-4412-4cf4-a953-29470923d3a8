{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@secure-task-management/auth": [
        "libs/api/auth/src/lib/rbac.service.ts"
      ],
      "@secure-task-management/auth/*": [
        "libs/api/auth/src/lib/*"
      ],
      "@secure-task-management/data": [
        "libs/api/data/src/lib/entities.ts"
      ],
      "@secure-task-management/data/*": [
        "libs/api/data/src/lib/*"
      ],
      "@secure-task-management/dashboard-auth": [
        "libs/dashboard/auth/src/lib/rbac.service.ts"
      ],
      "@secure-task-management/dashboard-auth/*": [
        "libs/dashboard/auth/src/lib/*"
      ],
      "@secure-task-management/dashboard-data": [
        "libs/dashboard/data/src/lib/entities.ts"
      ],
      "@secure-task-management/dashboard-data/enums": [
        "libs/dashboard/data/src/lib/enums.ts"
      ],
      "@secure-task-management/dashboard-design-system": [
        "libs/dashboard/design-system/src/lib/tokens.ts"
      ],
      "@secure-task-management/dashboard-design-system/*": [
        "libs/dashboard/design-system/src/lib/*"
      ],
      "@secure-task-management/shared-ui": [
        "libs/shared/ui/src/index.ts"
      ],
      "@secure-task-management/models": [
        "libs/models/src/index.ts"
      ],
      "@secure-task-management/services": [
        "libs/services/src/index.ts"
      ],
      "@secure-task-management/state": [
        "libs/state/src/index.ts"
      ]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
